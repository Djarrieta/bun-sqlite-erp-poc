# Copy to `.env` (git-ignored) and fill in. Bun auto-loads `.env`.

# --- Web app (existing) ---
PORT=4000
# First admin, seeded on boot when the users table is empty:
ADMIN_EMAIL=djarrieta@erp.com
ADMIN_PASSWORD=dariojose
# Numeric Telegram id linked to the seeded admin so they can use the bot
# (only linked users may chat with it). Send /start to the bot to get your id.
ADMIN_TELEGRAM_ID=

# --- Telegram bot (bun run bot) ---
# Bot token from @BotFather:
TELEGRAM_BOT_TOKEN=
# DeepSeek (OpenAI-compatible) credentials:
DEEPSEEK_API_KEY=
# Optional overrides:
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com
